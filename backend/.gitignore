# pyenv
#   For a library or app, you might want to share this in the repository.
#   For a development environment, you might want to ignore it.
# .python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of microservices, you may want to ignore it.
#Pipfile.lock

# poetry
#   Using Poetry supports standard lock files, which should be tracked.
# .poetry/lock

# pdm
#   Similar to Pipfile.lock, it is generally recommended to include pdm.lock in version control.
#pdm.lock
